# .env.example
# ============================================================================
# CẤU HÌNH BẢO MẬT — VCFE DATABASE
# Copy file này thành `.env` rồi điền giá trị THẬT, KHÔNG commit `.env` lên git.
# Hệ thống sẽ TỪ CHỐI khởi động nếu thiếu / để mặc định / quá yếu.
# ============================================================================

# ----- DB_PASSWORD: mật khẩu mã hoá SQLCipher -----
# - Tối thiểu 16 ký tự, gồm cả chữ và số.
# - Sinh chuỗi ngẫu nhiên đủ mạnh:
#       python -c "import secrets; print(secrets.token_urlsafe(32))"
# - LƯU GIỮ NGOÀI MÁY (két sắt / quản trị viên cấp 2). Mất key = mất dữ liệu.
DB_PASSWORD=

# ----- SECRET_KEY: khoá ký session cookie (itsdangerous) -----
# - Tối thiểu 32 ký tự.
# - Sinh:
#       python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ----- ADMIN_PASSWORD: mật khẩu super admin lần đầu -----
# - Tối thiểu 12 ký tự.
# - Hệ thống sẽ ép đổi ngay khi đăng nhập lần đầu (must_change_password=1).
ADMIN_PASSWORD=

# ----- Cờ vận hành -----
DEBUG=false
USE_HTTPS=false
DB_NAME=security_profile.db
UPLOAD_DIR=data/uploads
