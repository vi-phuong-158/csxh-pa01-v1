# .env.example
# ============================================================================
# CẤU HÌNH VẬN HÀNH — VCFE DATABASE
# Copy file này thành `.env` rồi điều chỉnh nếu cần.
#
# LƯU Ý: DB_PASSWORD, SECRET_KEY, ADMIN_PASSWORD KHÔNG còn ở đây.
# Các secret được nhập tương tác (ẩn ký tự) khi khởi động qua run_server.py.
# ============================================================================

# ----- Cờ vận hành -----
DEBUG=false
USE_HTTPS=false

# ----- Database -----
DB_NAME=security_profile.db

# ----- Upload -----
UPLOAD_DIR=data/uploads

# ----- Port (mặc định 8000) -----
# PORT=8000
